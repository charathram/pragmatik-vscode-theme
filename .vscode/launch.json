{
  // Press F5 to open an Extension Development Host with the Pragmatik theme
  // loaded. In that window: Cmd+K Cmd+T to pick a variant. Editing a
  // themes/*.json file hot-reloads the colors live.
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Pragmatik theme",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}",
        "${workspaceFolder}"
      ]
    }
  ]
}
